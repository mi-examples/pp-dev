{
  "compilerOptions": {
    "declaration": false,
    "lib": ["esnext", "dom"],
    "types": ["node"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "removeComments": false,
    "sourceMap": false,
    "strict": true,
    "target": "esnext",
    "outDir": "./dist",
    "rootDir": "./src",
    "skipLibCheck": true,

    /* Bundler mode */
    "resolveJsonModule": true,
    "isolatedModules": true,
    "allowSyntheticDefaultImports": true
  },
  "include": ["src/**/*.ts", "src/**/*.json"],
  "exclude": ["dist", "node_modules", "src/client"]
}
